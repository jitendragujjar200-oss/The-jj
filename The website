<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Geméra Fine Jewellery</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Tenor+Sans&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">

<style>
  :root {
    --green-deep:    #0d2b1e;
    --green-mid:     #14402c;
    --green-rich:    #1a5238;
    --gold:          #c9a96e;
    --gold-light:    #e2c898;
    --gold-pale:     #f0ddb0;
    --cream:         #faf6ed;
    --white-soft:    rgba(250,246,237,0.92);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--green-deep);
    color: var(--gold-light);
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  /* ── Custom cursor ── */
  .cursor {
    position: fixed; top: 0; left: 0; z-index: 9999;
    pointer-events: none;
  }
  .cursor-dot {
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    position: absolute;
    transform: translate(-50%, -50%);
    transition: transform 0.1s ease;
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1px solid var(--gold);
    border-radius: 50%;
    position: absolute;
    transform: translate(-50%, -50%);
    transition: transform 0.35s cubic-bezier(.22,.68,0,1.2), width 0.3s, height 0.3s, opacity 0.3s;
    opacity: 0.6;
  }
  body:hover .cursor-dot { opacity: 1; }

  /* ── Noise grain overlay ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 1000; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    opacity: 0.25;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    display: flex; align-items: center; justify-content: space-between;
    padding: 28px 60px;
    background: linear-gradient(to bottom, rgba(13,43,30,0.95) 0%, transparent 100%);
    backdrop-filter: blur(2px);
    animation: fadeDown 1.2s ease both;
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    color: var(--gold-light);
    text-transform: uppercase;
  }
  .nav-logo span { font-style: italic; color: var(--gold); }

  .nav-links {
    display: flex; gap: 44px; list-style: none;
  }
  .nav-links a {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: var(--gold-light);
    text-decoration: none;
    text-transform: uppercase;
    position: relative;
    transition: color 0.3s;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: -4px; left: 0; right: 0; height: 1px;
    background: var(--gold);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s cubic-bezier(.22,.68,0,1.2);
  }
  .nav-links a:hover { color: var(--gold-pale); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-cta {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--green-deep);
    background: var(--gold);
    padding: 10px 24px;
    border: none; cursor: none;
    transition: background 0.3s, transform 0.2s;
  }
  .nav-cta:hover {
    background: var(--gold-pale);
    transform: scale(1.02);
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  /* Left panel */
  .hero-left {
    display: flex; flex-direction: column;
    justify-content: center;
    padding: 140px 70px 80px 90px;
    position: relative; z-index: 2;
    animation: fadeLeft 1.4s 0.3s ease both;
  }
  @keyframes fadeLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .hero-eyebrow {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 36px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block; width: 40px; height: 1px;
    background: var(--gold);
    opacity: 0.7;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.8rem, 6vw, 6.5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--gold-light);
    margin-bottom: 8px;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold-pale);
    display: block;
  }
  .hero-title strong {
    font-weight: 500;
    display: block;
    font-size: 0.55em;
    letter-spacing: 0.25em;
    font-style: normal;
    font-family: 'Tenor Sans', sans-serif;
    color: var(--gold);
    margin-top: 12px;
  }

  .hero-divider {
    width: 80px; height: 1px;
    background: linear-gradient(to right, var(--gold), transparent);
    margin: 36px 0;
  }

  .hero-desc {
    font-size: 0.88rem;
    line-height: 1.95;
    color: rgba(210,190,155,0.75);
    max-width: 360px;
    letter-spacing: 0.04em;
    margin-bottom: 52px;
  }

  .hero-actions { display: flex; gap: 24px; align-items: center; }

  .btn-primary {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--green-deep);
    background: var(--gold);
    padding: 16px 40px;
    text-decoration: none;
    display: inline-block;
    position: relative; overflow: hidden;
    transition: color 0.35s;
  }
  .btn-primary::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--gold-pale);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(.22,.68,0,1.2);
  }
  .btn-primary:hover::before { transform: translateX(0); }
  .btn-primary span { position: relative; z-index: 1; }

  .btn-ghost {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    display: flex; align-items: center; gap: 12px;
    transition: gap 0.3s, color 0.3s;
  }
  .btn-ghost:hover { color: var(--gold-pale); gap: 18px; }
  .btn-ghost::after {
    content: '→';
    font-size: 1rem;
  }

  /* Right panel */
  .hero-right {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    animation: fadeRight 1.4s 0.5s ease both;
  }
  @keyframes fadeRight {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Geometric gem backdrop */
  .hero-bg-gem {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 55% 50%, rgba(26,82,56,0.55) 0%, transparent 70%),
      radial-gradient(ellipse 100% 80% at 50% 50%, rgba(20,64,44,0.3) 0%, transparent 80%);
  }

  .gem-frame {
    position: relative; z-index: 2;
    width: min(420px, 85%);
    aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
  }

  /* Octagonal gem border */
  .gem-frame::before {
    content: '';
    position: absolute; inset: 0;
    background: transparent;
    border: 1px solid rgba(201,169,110,0.3);
    clip-path: polygon(20% 0%, 80% 0%, 100% 20%, 100% 80%, 80% 100%, 20% 100%, 0% 80%, 0% 20%);
    animation: rotateSlow 20s linear infinite;
  }
  .gem-frame::after {
    content: '';
    position: absolute;
    inset: 16px;
    background: transparent;
    border: 1px solid rgba(201,169,110,0.15);
    clip-path: polygon(20% 0%, 80% 0%, 100% 20%, 100% 80%, 80% 100%, 20% 100%, 0% 80%, 0% 20%);
    animation: rotateSlow 20s linear infinite reverse;
  }
  @keyframes rotateSlow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Product placeholder card */
  .product-card {
    position: relative; z-index: 3;
    width: 260px;
    display: flex; flex-direction: column; align-items: center;
    gap: 24px;
  }

  .product-img-wrap {
    width: 200px; height: 260px;
    background: linear-gradient(135deg, rgba(26,82,56,0.8), rgba(13,43,30,0.9));
    border: 1px solid rgba(201,169,110,0.25);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .product-img-wrap::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 40% 35%, rgba(201,169,110,0.12), transparent 60%);
  }

  /* SVG ring illustration */
  .product-svg {
    width: 120px; height: 120px;
    opacity: 0.9;
  }

  .product-label {
    text-align: center;
  }
  .product-label h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--gold-light);
    margin-bottom: 4px;
  }
  .product-label p {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold); opacity: 0.7;
  }

  /* Corner ornaments */
  .corner { position: absolute; width: 28px; height: 28px; }
  .corner-tl { top: 36px; left: 36px; border-top: 1px solid var(--gold); border-left: 1px solid var(--gold); opacity: 0.4; }
  .corner-tr { top: 36px; right: 36px; border-top: 1px solid var(--gold); border-right: 1px solid var(--gold); opacity: 0.4; }
  .corner-bl { bottom: 36px; left: 36px; border-bottom: 1px solid var(--gold); border-left: 1px solid var(--gold); opacity: 0.4; }
  .corner-br { bottom: 36px; right: 36px; border-bottom: 1px solid var(--gold); border-right: 1px solid var(--gold); opacity: 0.4; }

  /* Side number */
  .hero-number {
    position: absolute; right: 40px; bottom: 60px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem; font-weight: 300;
    color: rgba(201,169,110,0.07);
    line-height: 1;
    letter-spacing: -0.02em;
    user-select: none;
    z-index: 1;
  }

  /* Vertical label */
  .hero-vert-label {
    position: absolute; left: 20px; top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold); opacity: 0.45;
    white-space: nowrap;
    z-index: 2;
  }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute; bottom: 36px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.55rem; letter-spacing: 0.3em;
    text-transform: uppercase; color: var(--gold); opacity: 0.5;
    animation: fadeIn 2s 1.5s ease both;
    z-index: 10;
  }
  .scroll-hint-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50%       { opacity: 0.8; transform: scaleY(1.1); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 0.5; }
  }

  /* ── MARQUEE STRIP ── */
  .marquee-strip {
    border-top: 1px solid rgba(201,169,110,0.15);
    border-bottom: 1px solid rgba(201,169,110,0.15);
    padding: 14px 0; overflow: hidden;
    background: rgba(20,64,44,0.2);
    position: relative; z-index: 2;
  }
  .marquee-track {
    display: flex; gap: 60px;
    animation: marquee 24s linear infinite;
    width: max-content;
  }
  .marquee-item {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold); opacity: 0.55;
    white-space: nowrap;
    display: flex; align-items: center; gap: 60px;
  }
  .marquee-item::after { content: '✦'; font-size: 0.5rem; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── BESPOKE COLLECTIONS ── */
  .collections {
    padding: 120px 90px;
    position: relative; z-index: 2;
  }

  .section-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 70px;
  }
  .section-eyebrow {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.6rem; letter-spacing: 0.4em;
    text-transform: uppercase; color: var(--gold);
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 16px;
  }
  .section-eyebrow::before {
    content: ''; width: 40px; height: 1px;
    background: var(--gold); opacity: 0.6;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 3.5vw, 3.8rem);
    font-weight: 300; line-height: 1.1;
    color: var(--gold-light);
  }
  .section-title em { font-style: italic; color: var(--gold-pale); }

  .section-link {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.62rem; letter-spacing: 0.28em;
    text-transform: uppercase; color: var(--gold);
    text-decoration: none;
    display: flex; align-items: center; gap: 12px;
    padding-bottom: 20px;
    transition: gap 0.3s, opacity 0.3s;
    opacity: 0.75;
  }
  .section-link:hover { gap: 18px; opacity: 1; }
  .section-link::after { content: '→'; }

  /* Collection grid */
  .collection-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 2px;
  }

  .col-card {
    position: relative; overflow: hidden;
    background: var(--green-mid);
    cursor: none;
  }
  .col-card:first-child {
    grid-row: 1 / 3;
  }
  .col-card-inner {
    aspect-ratio: 3/4;
    background: linear-gradient(145deg, rgba(26,82,56,0.9), rgba(13,43,30,1));
    display: flex; align-items: flex-end;
    padding: 32px;
    position: relative; overflow: hidden;
    transition: transform 0.6s cubic-bezier(.22,.68,0,1.2);
  }
  .col-card:first-child .col-card-inner {
    aspect-ratio: auto; height: 100%;
  }
  .col-card:hover .col-card-inner { transform: scale(1.02); }

  .col-card-inner::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(201,169,110,0.08), transparent 60%);
  }

  /* placeholder gem icon per card */
  .col-icon {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -60%);
    opacity: 0.18;
  }

  .col-info { position: relative; z-index: 2; }
  .col-info h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem; font-weight: 400;
    color: var(--gold-light); margin-bottom: 6px;
    letter-spacing: 0.05em;
  }
  .col-info p {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.58rem; letter-spacing: 0.3em;
    text-transform: uppercase; color: var(--gold); opacity: 0.6;
  }

  .col-border {
    position: absolute; inset: 12px;
    border: 1px solid rgba(201,169,110,0.12);
    pointer-events: none;
    transition: border-color 0.4s;
  }
  .col-card:hover .col-border { border-color: rgba(201,169,110,0.3); }

  /* ── CRAFTSMANSHIP ── */
  .craft {
    padding: 120px 90px;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 90px; align-items: center;
    border-top: 1px solid rgba(201,169,110,0.1);
    position: relative; z-index: 2;
  }

  .craft-visual {
    position: relative;
  }
  .craft-img-frame {
    width: 100%;
    aspect-ratio: 4/5;
    background: linear-gradient(135deg, var(--green-mid) 0%, var(--green-deep) 100%);
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .craft-img-frame::before {
    content: '';
    position: absolute; inset: -12px;
    border: 1px solid rgba(201,169,110,0.18);
  }
  .craft-img-frame::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 40% 40%, rgba(201,169,110,0.1), transparent 65%);
  }

  .craft-svg {
    width: 160px; opacity: 0.25; z-index: 1; position: relative;
  }

  .craft-badge {
    position: absolute; bottom: -20px; right: -20px;
    width: 110px; height: 110px;
    background: var(--gold);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 2px;
  }
  .craft-badge span:first-child {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 500;
    color: var(--green-deep); line-height: 1;
  }
  .craft-badge span:last-child {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.5rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--green-deep);
  }

  .craft-content {}
  .craft-content .section-eyebrow { margin-bottom: 20px; }
  .craft-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 3vw, 3.5rem);
    font-weight: 300; line-height: 1.1;
    color: var(--gold-light); margin-bottom: 30px;
  }
  .craft-content h2 em { font-style: italic; color: var(--gold-pale); }
  .craft-content p {
    font-size: 0.87rem; line-height: 2;
    color: rgba(210,190,155,0.65);
    letter-spacing: 0.03em;
    margin-bottom: 20px;
  }

  .craft-stats {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 30px 40px; margin-top: 50px;
    padding-top: 40px;
    border-top: 1px solid rgba(201,169,110,0.15);
  }
  .stat {}
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem; font-weight: 300;
    color: var(--gold-light); line-height: 1;
    margin-bottom: 6px;
  }
  .stat-label {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.58rem; letter-spacing: 0.3em;
    text-transform: uppercase; color: var(--gold); opacity: 0.6;
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid rgba(201,169,110,0.12);
    padding: 60px 90px;
    display: flex; align-items: center; justify-content: space-between;
    position: relative; z-index: 2;
    background: rgba(13,43,30,0.5);
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase; color: var(--gold-light);
  }
  .footer-logo span { font-style: italic; color: var(--gold); }
  .footer-copy {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.58rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--gold); opacity: 0.35;
  }
  .footer-links {
    display: flex; gap: 32px; list-style: none;
  }
  .footer-links a {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 0.58rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--gold);
    text-decoration: none; opacity: 0.5;
    transition: opacity 0.3s;
  }
  .footer-links a:hover { opacity: 1; }

  /* ── Gem SVG used inline ── */
  svg.gem-icon path { stroke: var(--gold); fill: none; stroke-width: 1; }
</style>
</head>
<body>

<!-- Custom cursor -->
<div class="cursor" id="cursor">
  <div class="cursor-ring" id="cursorRing"></div>
  <div class="cursor-dot" id="cursorDot"></div>
</div>

<!-- ── NAV ── -->
<nav>
  <div class="nav-logo">Gem<span>é</span>ra</div>
  <ul class="nav-links">
    <li><a href="#">Collections</a></li>
    <li><a href="#">Bespoke</a></li>
    <li><a href="#">Craftsmanship</a></li>
    <li><a href="#">Ateliers</a></li>
  </ul>
  <button class="nav-cta">Book a Consultation</button>
</nav>

<!-- ── HERO ── -->
<section class="hero">
  <!-- Left -->
  <div class="hero-left">
    <div class="hero-eyebrow">New Haute Joaillerie Collection</div>
    <h1 class="hero-title">
      <em>The Art
